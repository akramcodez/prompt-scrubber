{
  "name": "prompt-scrub",
  "version": "1.0.0",
  "packageManager": "pnpm@11.0.9",
  "type": "module",
  "description": "`prompt-scrub` is a small open-source, local-first utility designed to strip identifying content out of prompts and messages before they hit any cloud LLM. It maps your sensitive data (emails, secrets, paths) to stable placeholders, allowing you to rehydrate the model's responses back to their original forms locally.",
  "main": "index.js",
  "bin": {
    "prompt-scrub": "./dist/cli/index.js"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/cli/index.js",
    "pretest": "pnpm run test:types",
    "test": "pnpm run test:ava",
    "test:watch": "ava --watch",
    "test:coverage": "pnpm run test:ava:coverage",
    "check": "pnpm run test:all",
    "lint": "pnpm run test:lint",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test:all": "bash scripts/test.sh",
    "test:format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test:types": "tsc --noEmit",
    "test:lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test:lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test:ava": "ava",
    "test:ava:coverage": "c8 --reporter=text --reporter=json-summary ava",
    "test:knip": "knip",
    "test:audit": "pnpm audit --audit-level=high --ignore-unfixable",
    "test:security": "semgrep scan --config auto --error"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nano-Collective/prompt-scrubber.git"
  },
  "keywords": [],
  "author": "Nano Collective",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Nano-Collective/prompt-scrubber/issues"
  },
  "homepage": "https://github.com/Nano-Collective/prompt-scrubber#readme",
  "devDependencies": {
    "@ava/typescript": "^7.0.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "ava": "^5.3.1",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "knip": "^6.20.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "nodeArguments": [
      "--no-warnings",
      "--import=tsx"
    ],
    "files": [
      "tests/**/*.test.ts"
    ]
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
